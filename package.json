{
  "name": "qobuz-dl-cli",
  "version": "2.0.0",
  "description": "Standalone command-line interface for downloading music from Qobuz",
  "type": "module",
  "bin": {
    "qobuz-dl": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "commander": "^12.1.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1",
    "socks-proxy-agent": "^8.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint": "^9",
    "prettier": "^3.6.2",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
